# Example .env for helm-net

# REQUIRED: gossipsub topic / network name for peer communication.
HELM_NETWORK_NAME=helm-testnet

# Optional HTTP API port. Defaults to 3000 if omitted.
HELM_API_PORT=3333

# Optional libp2p peer-to-peer port. OS-assigned if omitted.
HELM_P2P_PORT=9000

# REQUIRED: hex-encoded 32-byte ed25519 secret key (64 hex chars).
# You may also set SECRET_KEY instead of HELM_SECRET_KEY as a fallback.
HELM_SECRET_KEY=

# Mining difficulty in bytes (0-256). Enables mining when set.
# Higher values require more work per block.
HELM_MINING_DIFFICULTY=20

# Number of blocks to fetch per sync chunk. Defaults to 16 if omitted.
HELM_BLOCK_CHUNK_SIZE=16

# Indexing database configuration (used by helm-db)
# Optional filesystem path where the index DB will be stored. If omitted,
# the DB will use an in-memory backend.
# Examples: ./helm-index-db, /var/lib/helm/index
HELM_INDEX_DB_PATH=./.helm-index.db

# Path to the block file where raw blocks are stored on-disk.
# Optional filesystem path where the blocks will be stored. If omitted,
# no block ledger will be used.
HELM_BLOCK_FILE=.blocks.dat
